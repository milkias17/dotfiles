{
  "suggest.completionItemKindLabels": {
    "method": " юЮЫ ",
    "function": " юЮЫ ",
    "variable": "[юЬЦ]",
    "field": " юЬЦ ",
    "typeParameter": "<яЮГ>",
    "constant": " яЫ╝ ",
    "class": " яаЦ ",
    "interface": " яиа",
    "struct": " яЖ│ ",
    "event": " яГз ",
    "operator": " яЪФ ",
    "module": " яЩи ",
    "property": " яВн ",
    "enum": " яйЧ",
    "reference": " яТБ ",
    "keyword": " яЭз ",
    "file": " яЕЫ ",
    "folder": " яБ╝я▒о",
    "color": " юИл ",
    "unit": " яем ",
    "snippet": " яЧП ",
    "text": " яФл ",
    "constructor": " юИП ",
    "value": " явЯ ",
    "enumMember": " яЕЭ ",
    "default": " юШТ "
  },

  // diagnostics
  "diagnostic.errorSign": "яАН ",
  "diagnostic.warningSign": "яБ▒ ",
  "diagnostic.infoSign": "яДй",
  "diagnostic.hintSign": "яВн ",

  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "java",
    "html",
    "markdown",
    "javascript",
    "jsonc",
    "json",
    "python"
  ],

  // explorer
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": ["expandable?", "expand", "open"],
    "v": "open:vsplit"
  },

  "coc.preferences.extensionUpdateCheck": "weekly",

  // Python
  "jedi.workspace.symbols.ignoreFolders": [
    ".nox",
    ".tox",
    ".venv",
    "__pycache__",
    "venv"
  ],

  // C
  "languageserver": {
    "ccls": {
      "command": "ccls",
      "filetypes": ["c", "cpp", "objc", "objcc"],
      "rootPatterns": [
        ".ccls",
        "compile_commands.json",
        ".vim/",
        ".git/",
        ".hg/"
      ],
      "initializationOptions": {
        "cache": {
          "directory": "/tmp/ccls"
        }
      }
    }
  }
}
